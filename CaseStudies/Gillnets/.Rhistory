plot(SEL5,standardize=T,Master=F) #Use standardize=T to set maximum retention to 1
#Add plot legend
legend(600,0.3,legend=paste(Meshs,"mm"),lty=1:5,col=1:5,cex=0.8)
par(oma=c(0,0,0,0),mar=c(4,4,1,4),las=1)
plot(SEL5,standardize=T,Master=F) #Use standardize=T to set maximum retention to 1
#Add plot legend
legend(600,0.3,legend=paste(Meshs,"mm"),lty=1:5,col=1:5,cex=0.8)
