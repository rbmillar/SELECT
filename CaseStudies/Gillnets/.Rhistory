#devtools::install_github("rbmillar/SELECT")
require(SELECT)
require(tidyverse)
data(Trout)
Trout
Meshs=Trout$Meshsize
Counts=Trout$Counts
Vars=names(Counts)
SEL1=SELECT(Counts,Vars,dtype="dc",
stype="norm.loc",Meshsize=Meshs)
AIC1=AIC(SEL1,type="Poisson")
SEL2=SELECT(Counts,Vars,dtype="dc",
stype="norm.sca",Meshsize=Meshs)
AIC2=AIC(SEL2,type="Poisson")
SEL3=SELECT(Counts,Vars,dtype="dc", stype="gamma",Meshsize=Meshs)
AIC3=AIC(SEL3,type="Poisson")
SEL4=SELECT(Counts,Vars,dtype="dc", stype="lognorm",Meshsize=Meshs)
AIC4=AIC(SEL4,type="Poisson")
SEL5=SELECT(Counts,Vars,dtype="dc",
stype="binorm.sca",Meshsize=Meshs)
AIC5=AIC(SEL5,type="Poisson")
SEL6=SELECT(Counts,Vars,dtype="dc",
stype="bilognorm",Meshsize=Meshs)
AIC6=AIC(SEL6,type="Poisson")
cat("Poisson AICs are",AIC1,AIC2,AIC3,AIC4,AIC5,AIC6)
ModelCheck(SEL5)
cat("Goodness of fit  p-value is",1-pchisq(80.6,67))
par(oma=c(0,0,0,0),mar=c(4,4,1,4))
plot(SEL5,standardize=T) #Use standardize=T to set maximum retention to 1
#Add plot legend
legend(600,0.3,legend=paste(Meshs,"mm"),lty=1:5,col=1:5,cex=0.8)
plot.SELECT
par(oma=c(0,0,0,0),mar=c(4,4,1,4))
plot(SEL5,standardize=T,Master=T) #Use standardize=T to set maximum retention to 1
#Add plot legend
legend(600,0.3,legend=paste(Meshs,"mm"),lty=1:5,col=1:5,cex=0.8)
par(oma=c(0,0,0,0),mar=c(4,4,1,4))
plot(SEL5,standardize=T,Master=F) #Use standardize=T to set maximum retention to 1
#Add plot legend
legend(600,0.3,legend=paste(Meshs,"mm"),lty=1:5,col=1:5,cex=0.8)
