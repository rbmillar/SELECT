require(SELECT)
require(dplyr)
require(ggplot2) #For bootstrap plot
#Read in data and remove zero catch lengths
Stow.df=read.csv("../Data/LgSq.csv",header=T) #343 rows
Stow.df=subset(Stow.df,total>0) #213 rows
#Quick peek at data
head(Stow.df)
v.names=c("lgth","cover","codend")
q.names=c("qcover","qcodend")
Tots=Raw2Tots(Stow.df,v.names,q.names)
Tots=transform(Tots,n=codend+cover,y=codend/(codend+cover))
Tots
plot(y~lgth,data=Tots,xlab="Carapace length (mm)",ylab="Propn retained")
require(mgcv)
Spline.fit=SplineSELECT(Stow.df,var.names=v.names,q.names=q.names,
k=5,bs="cr",quasi=F)
AIC(Spline.fit)
plot(Tots$lgth,resid(Spline.fit),type="h")
abline(h=0)
par(mar=c(4,4,1,1),las=1)
lgth.seq=seq(6,23,0.1)
plot(y~lgth,data=Tots,xlab="Carapace length (mm)",ylab="Propn retained")
points(lgth.seq,predict(Spline.fit,data.frame(lgth=lgth.seq),type="response"),type="l")
# Build the cubic B-spline basis using mgcv's smooth constructor
par(mar=c(4,4,1,1),las=1)
smCR=smoothCon(s(lgth.seq, bs="cr", k=5),
data=data.frame(lgth.seq=lgth.seq))
B=smCR[[1]]$X  # The basis matrix
knots=smCR[[1]]$xp #Use $knots if bs="bs"
# Plot
matplot(lgth.seq, B, type="l", lty=c(1,2,4,5,6,1,2), lwd=1.5,
col="black",
xlab="Carapace length (mm)",ylab="Spline basis")
# Add vertical dotted lines at knots
abline(v=knots, lty=3, col="black")
