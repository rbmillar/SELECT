TotsZ=rbind(Tots[1,],c(7,0,0),Tots[-1,]) #With zero catch length
Tots=transform(Tots,n=codend+cover,y=codend/(codend+cover))
plot(y~lgth,data=Tots,xlab="Carapace length (mm)",ylab="Propn retained")
TotsZ
Spline.fitZ=SplineSELECT(TotsZ,var.names=v.names,
k=5,bs="cr",quasi=F)
fitted(Spline.fit)
fitted(Spline.fitZ)[-2]
dim(Tots)
dim(TotsZ)
itted(Spline.fitZ)
fitted(Spline.fitZ)
Spline.fit$knots
Spline.fit$xp
names(Spline.fit)
View(Spline.fit)
Spline.fit$xp
Spline.fit[[1]]$xp
Spline.fit$smooth[[1]]$xp
#eta=Spline.fit$linear.predictors
#eta2=predict(Spline.fit,type="lpmatrix")%*%Spline.fit$coef
#max(eta-eta2)
#[1] 8.881784e-16 #Works
B=predict(Spline.fit,newdata=data.frame(lgth=lgth.seq),type="lpmatrix")
knots=Spline.fit$smooth[[1]]$xp
matplot(lgth.seq,B,type="l",lty=c(1,2,4,5,6,1,2), lwd=1.5,col="black",
xlab="Carapace length (mm)",ylab="Spline bases")
# Add vertical dotted lines at knots
abline(v=knots, lty=3, col="black")
getwed()
getwd()
